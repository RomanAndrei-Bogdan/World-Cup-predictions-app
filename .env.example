# Copiază în .env.local și completează.

# Secret pentru semnarea sesiunilor (orice șir aleatoriu, minim 16 caractere).
SESSION_SECRET=

# Codul pe care îl dai prietenilor ca să se poată înscrie.
GROUP_CODE=mondial2026

# Token gratuit: cont la https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=

# Baza de date. Local: lasă gol (folosește fișierul local.db).
# Producție (Vercel): creează o bază gratuită pe https://turso.tech
# DATABASE_URL=libsql://numele-bazei-user.turso.io
# DATABASE_AUTH_TOKEN=

# Opțional: secret pentru sincronizare prin cron extern (antet x-cron-secret).
# CRON_SECRET=
